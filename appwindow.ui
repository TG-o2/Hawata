      <property name="styleSheet">
       <string notr="true">QPushButton {
    background-color: #0A3D62;        /* Deep premium blue from the logo */
    color: white;
    font-size: 18px;
    font-weight: bold;
    font-family: &quot;Poppins&quot;, &quot;Segoe UI&quot;, sans-serif;
    border: none;
    border-radius: 12px;              /* Softer, more modern rounding */
    padding: 14px 32px;               /* More generous padding */
    min-height: 52px;                 /* Comfortable button height */
}

QPushButton:hover {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
        stop:0 #1E5A94,
        stop:1 #0F4A7F);
    box-shadow: 0 4px 12px rgba(10, 61, 98, 0.3); /* Subtle glow on hover */
}

QPushButton:pressed {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
        stop:0 #072E4F,
        stop:1 #0A3D62);
    padding-top: 16px;
    padding-bottom: 12px;             /* Slight press effect */
}</string>
